void setup() {
  Serial.begin(115200);

  Wire.begin(D2, D1);

  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("SSD1306 fail");
    while (true) {}
  }
display.clearDisplay();
display.setTextSize(1);
display.setTextColor(SSD1306_WHITE);

display.drawBitmap(2, 10, respire_logo_bitmapRespire_PCB__logo, 124, 39, WHITE);
display.display();
delay(4000);

display.clearDisplay();
// -------- Line 1 --------
String line1 = "AIR & AQUA";
int x1 = (128 - (line1.length() * 6)) / 2;
display.setCursor(x1, 20);
display.println(line1);

// -------- Line 2 --------
String line2 = "QUALITY ANALYZER";
int x2 = (128 - (line2.length() * 6)) / 2;
display.setCursor(x2, 32);
display.println(line2);

display.display();
delay(3000);

dht.begin();
pinMode(MQ135_PIN, INPUT);
}

